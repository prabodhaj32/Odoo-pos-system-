<odoo>

<record id="view_order_list" model="ir.ui.view">
    <field name="name">shop.pos.order.list</field>
    <field name="model">shop.pos.order</field>
    <field name="arch" type="xml">
        <list>
            <field name="product_id"/>
            <field name="qty"/>
            <field name="total"/>
        </list>
    </field>
</record>

<record id="view_order_form" model="ir.ui.view">
    <field name="name">shop.pos.order.form</field>
    <field name="model">shop.pos.order</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="product_id"/>
                    <field name="qty"/>
                    <field name="total"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

</odoo>