<odoo>

<record id="view_product_list" model="ir.ui.view">
    <field name="name">shop.pos.product.list</field>
    <field name="model">shop.pos.product</field>
    <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="price"/>
            <field name="quantity"/>
        </list>
    </field>
</record>

<record id="view_product_form" model="ir.ui.view">
    <field name="name">shop.pos.product.form</field>
    <field name="model">shop.pos.product</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="price"/>
                    <field name="quantity"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

</odoo>